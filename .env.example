# Copy to .env for local dev (outside Docker) or set in docker-compose

NODE_ENV=development
SV_ENV=development

# PostgreSQL on shared_network (container: shared_postgres)
# Local dev (pnpm dev on host): use localhost:5432
DATABASE_URL=postgresql://platform:platform@localhost:5432/stock_verifier

# Redis on shared_network (container: shared_redis) — DB 1 reserved for Script Screener
# Local dev (pnpm dev on host): use localhost:6379
REDIS_URL=redis://localhost:6379/1

# JWT secrets — change in production
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# Optional break-glass API key (parity with PHP SV_ADMIN_KEY)
# SV_ADMIN_KEY=

# API / Web ports (host mapping)
API_PORT=3100
WEB_PORT=5173

# CORS origin for React dev server
CORS_ORIGIN=http://localhost:5173

# Default admin (seed) — only used on first db:seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
