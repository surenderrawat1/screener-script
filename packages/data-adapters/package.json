{
  "name": "@sv/data-adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "sync:indices": "tsx src/sync-indices-cli.ts",
    "daily:sync": "tsx src/daily-sync-cli.ts"
  },
  "dependencies": {
    "@sv/cache": "workspace:*",
    "@sv/core": "workspace:*",
    "@sv/db": "workspace:*",
    "@sv/jobs": "workspace:*",
    "@sv/shared": "workspace:*",
    "@sv/swing": "workspace:*",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
