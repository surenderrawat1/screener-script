{
  "name": "@sv/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "push": "prisma db push",
    "seed": "tsx src/seed.ts",
    "seed:cfa": "tsx -e \"import { seedCfaTerms } from './src/seed-cfa-terms.ts'; seedCfaTerms().then(r => console.log(r)).finally(() => process.exit(0))\"",
    "migrate:php": "tsx src/migrate-php-data.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@sv/shared": "workspace:*",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
